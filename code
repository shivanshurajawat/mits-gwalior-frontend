  <!-- back to top button -->
  <button id="backToTop" onclick="window.scrollTo({top:0,behavior:'smooth'})">
    <i class="fas fa-arrow-up"></i>
  </button>

  <!-- bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // back to top
    window.onscroll = function() {
      var btn = document.getElementById('backToTop');
      if (document.documentElement.scrollTop > 300) {
        btn.style.display = 'block';
      } else {
        btn.style.display = 'none';
      }
    };

    // filter programs
    function filterProgs(cat, btn) {
      document.querySelectorAll('.prog-tabs button').forEach(function(b) {
        b.classList.remove('active');
      });
      btn.classList.add('active');

      document.querySelectorAll('.prog-item').forEach(function(item) {
        if (cat === 'all' || item.dataset.cat === cat) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    }

    // form submit feedback
    function handleSubmit(btn) {
      btn.innerHTML = '<i class="fas fa-check me-2"></i> Message Sent!';
      btn.style.background = '#43a047';
      setTimeout(function() {
        btn.innerHTML = '<i class="fas fa-paper-plane me-2"></i> Send Message';
        btn.style.background = '';
      }, 3000);
    }

    // build march 2025 calendar
    var eventDays = [10, 15, 22, 28];
    var firstDay = 6;
    var totalDays = 31;
    var todayDate = new Date().getDate();

    var calBody = document.getElementById('calBody');
    var day = 1;
    var rows = Math.ceil((firstDay + totalDays) / 7);

    for (var r = 0; r < rows; r++) {
      var tr = document.createElement('tr');
      for (var c = 0; c < 7; c++) {
        var td = document.createElement('td');
        var idx = r * 7 + c;
        if (idx < firstDay || day > totalDays) {
          td.className = 'empty';
        } else {
          td.textContent = day;
          if (day === 28) {
            td.className = 'today';
          } else if (eventDays.indexOf(day) !== -1) {
            td.className = 'has-event';
          }
          day++;
        }
        tr.appendChild(td);
      }
      calBody.appendChild(tr);
    }
  </script>

</body>
